{
  "name": "weekendworthy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "find": "pnpm build && node --env-file=.env dist/index.js",
    "find:dev": "pnpm build && DEV_LIMIT=2 node --env-file=.env dist/index.js",
    "find:md": "pnpm build && node --env-file=.env dist/index.js --format md"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.12.12"
  }
}

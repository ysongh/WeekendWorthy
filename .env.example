NIMBLE_API_KEY=
ANTHROPIC_API_KEY=

# Senso.ai — required for `pnpm senso` / `pnpm senso:dev`
SENSO_API_KEY=
# Created via `senso content-types create` (see CLAUDE.md / README)
SENSO_CONTENT_TYPE_ID=
# Created via `senso questions create`
SENSO_GEO_QUESTION_ID=

# Optional: cap number of items during development (queries for find:dev,
# problems-to-ingest for senso:dev)
# DEV_LIMIT=3

# Optional: dump raw Claude reply + input from the distillation step
# DEBUG_DISTILL=1

# Optional: override the problems file path for the Senso flow (default: problems.json)
# PROBLEMS_PATH=problems.json
